# ─── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# On the server, set these as Docker build arguments (see docker-compose.yml).
# ─────────────────────────────────────────────────────────────────────────────

# ── Saleor GraphQL API ────────────────────────────────────────────────────────
# The full URL to your Saleor storefront GraphQL endpoint.
VITE_SALEOR_API_URL=https://saleor.leemasmart.com/graphql/

# ── Site Identity ─────────────────────────────────────────────────────────────
VITE_SITE_NAME=Leema

# ── Shiprocket Checkout ───────────────────────────────────────────────────────
# Base URL of the Shiprocket app service that generates checkout tokens.
VITE_SHIPROCKET_APP_URL=https://shiprocket.leemasmart.com

# ── Auth Token Storage Keys ───────────────────────────────────────────────────
# Keys used to store authentication tokens in localStorage.
VITE_TOKEN_STORAGE_KEY=authToken
VITE_REFRESH_TOKEN_KEY=refreshToken

# ── Analytics (optional) ─────────────────────────────────────────────────────
VITE_GA_TRACKING_ID=
VITE_GTM_ID=
